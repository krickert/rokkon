{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rokkon.search/schemas/tika-parser-config.json",
  "title": "Tika Parser Configuration Schema",
  "description": "Configuration schema for the Tika document parser module",
  "type": "object",
  "properties": {
    "maxContentLength": {
      "type": "integer",
      "description": "Maximum number of characters to extract from documents",
      "minimum": 1,
      "maximum": 100000000,
      "default": 10000000
    },
    "extractMetadata": {
      "type": "boolean",
      "description": "Whether to extract and include document metadata",
      "default": true
    },
    "enableGeoTopicParser": {
      "type": "boolean",
      "description": "Enable GeoTopicParser for location extraction",
      "default": false
    },
    "extractEmbeddedDocs": {
      "type": "boolean",
      "description": "Whether to extract embedded documents (e.g., attachments)",
      "default": true
    },
    "parseTimeoutSeconds": {
      "type": "integer",
      "description": "Timeout for parsing operations in seconds",
      "minimum": 1,
      "maximum": 600,
      "default": 60
    },
    "maxRecursionDepth": {
      "type": "integer",
      "description": "Maximum recursion depth for embedded documents",
      "minimum": 1,
      "maximum": 50,
      "default": 10
    },
    "enableOcr": {
      "type": "boolean",
      "description": "Enable OCR processing for images and scanned documents",
      "default": false
    },
    "ocrStrategy": {
      "type": "string",
      "description": "OCR processing strategy",
      "enum": ["OCR_ONLY", "OCR_AND_TEXT_EXTRACTION", "AUTO"],
      "default": "OCR_ONLY"
    },
    "ocrLanguage": {
      "type": "string",
      "description": "Language code for OCR processing",
      "pattern": "^[a-z]{2,3}(\\+[a-z]{2,3})*$",
      "default": "eng"
    },
    "ocrTimeoutSeconds": {
      "type": "integer",
      "description": "Timeout for OCR operations in seconds",
      "minimum": 1,
      "maximum": 300,
      "default": 120
    },
    "enableXTikaContent": {
      "type": "boolean",
      "description": "Enable X-Tika-Content header processing",
      "default": false
    },
    "flattenCompound": {
      "type": "boolean",
      "description": "Flatten compound documents into single content stream",
      "default": false
    },
    "ignoreTikaException": {
      "type": "boolean",
      "description": "Continue processing even if Tika throws exceptions",
      "default": false
    },
    "passwordFilePath": {
      "type": "string",
      "description": "Path to file containing passwords for encrypted documents",
      "format": "uri-reference"
    },
    "enablePasswordExtraction": {
      "type": "boolean",
      "description": "Enable automatic password extraction attempts",
      "default": false
    },
    "customTikaConfig": {
      "type": "string",
      "description": "Custom Tika configuration XML content",
      "contentMediaType": "application/xml"
    },
    "parserBlacklist": {
      "type": "array",
      "description": "List of parser class names to disable",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z][a-zA-Z0-9_]*(\\.([a-zA-Z][a-zA-Z0-9_]*))*$"
      },
      "uniqueItems": true
    },
    "parserWhitelist": {
      "type": "array",
      "description": "List of parser class names to enable (all others disabled)",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z][a-zA-Z0-9_]*(\\.([a-zA-Z][a-zA-Z0-9_]*))*$"
      },
      "uniqueItems": true
    },
    "mimeTypeOverrides": {
      "type": "object",
      "description": "File extension to MIME type mappings",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-zA-Z]+/[a-zA-Z0-9][a-zA-Z0-9!#$&\\-\\^_]*$"
      }
    },
    "enableDebugLogging": {
      "type": "boolean",
      "description": "Enable debug-level logging for Tika operations",
      "default": false
    },
    "tempDirectory": {
      "type": "string",
      "description": "Directory for temporary files during processing",
      "format": "uri-reference"
    },
    "maxFileSize": {
      "type": "integer",
      "description": "Maximum file size to process in bytes",
      "minimum": 1,
      "maximum": 1073741824,
      "default": 104857600
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "maxContentLength": 1000000,
      "extractMetadata": true,
      "enableOcr": false,
      "parseTimeoutSeconds": 30
    },
    {
      "maxContentLength": 5000000,
      "extractMetadata": true,
      "enableOcr": true,
      "ocrLanguage": "eng+fra",
      "ocrTimeoutSeconds": 180,
      "enableGeoTopicParser": true,
      "parserBlacklist": ["org.apache.tika.parser.microsoft.EMFParser"]
    }
  ]
}